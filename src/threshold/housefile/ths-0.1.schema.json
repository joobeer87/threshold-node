{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://threshold.local/schema/ths-0.1.json",
  "title": "Housefile THS-0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "rev", "dwelling", "zones", "policies"],
  "properties": {
    "schema": {"const": "ths/0.1"},
    "rev": {"type": "string", "pattern": "^[A-Z]{1,8}$"},
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["synthetic", "notice"],
      "properties": {
        "synthetic": {"const": true},
        "notice": {"type": "string", "minLength": 1, "maxLength": 240}
      }
    },
    "dwelling": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {"type": "string", "minLength": 1, "maxLength": 128},
        "type": {"type": "string", "minLength": 1, "maxLength": 80}
      }
    },
    "zones": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "access", "boundary"],
        "properties": {
          "id": {"type": "string", "minLength": 1, "maxLength": 80, "pattern": "^[a-z0-9][a-z0-9._-]*$"},
          "name": {"type": "string", "minLength": 1, "maxLength": 80},
          "access": {"enum": ["open", "restricted", "no-go"]},
          "boundary": {
            "type": "array",
            "items": {"type": "number"},
            "minItems": 4,
            "maxItems": 4
          },
          "note": {"type": "string", "maxLength": 240},
          "outdoor": {"type": "boolean"}
        }
      }
    },
    "systems": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "zone", "tag", "detail"],
        "properties": {
          "id": {"type": "string", "minLength": 1, "maxLength": 80},
          "name": {"type": "string", "minLength": 1, "maxLength": 128},
          "zone": {"type": "string", "minLength": 1, "maxLength": 80},
          "tag": {"enum": ["water", "power", "hvac", "net"]},
          "detail": {"type": "string", "maxLength": 240}
        }
      }
    },
    "inventory": {
      "type": "array",
      "maxItems": 512,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "zone"],
        "properties": {
          "id": {"type": "string", "minLength": 1, "maxLength": 80},
          "name": {"type": "string", "minLength": 1, "maxLength": 128},
          "zone": {"type": "string", "minLength": 1, "maxLength": 80},
          "flags": {
            "type": "array",
            "maxItems": 16,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1, "maxLength": 80}
          },
          "note": {"type": "string", "maxLength": 240}
        }
      }
    },
    "quirks": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "zone", "text"],
        "properties": {
          "id": {"type": "string", "minLength": 1, "maxLength": 80},
          "zone": {"type": "string", "minLength": 1, "maxLength": 80},
          "text": {"type": "string", "minLength": 1, "maxLength": 240}
        }
      }
    },
    "policies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["quietHours"],
      "properties": {
        "quietHours": {
          "type": "object",
          "required": ["start", "end", "timezone"],
          "properties": {
            "start": {"type": "string", "pattern": "^(?:[01][0-9]|2[0-3]):[0-5][0-9]$"},
            "end": {"type": "string", "pattern": "^(?:[01][0-9]|2[0-3]):[0-5][0-9]$"},
            "timezone": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9._+-]+(?:/[A-Za-z0-9._+-]+)*$"
            }
          },
          "additionalProperties": false
        },
        "teleop": {"enum": ["per-session", "never"]},
        "residency": {"type": "string", "maxLength": 80}
      }
    },
    "materialization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "geometry_sha256", "algorithm", "zones"],
      "properties": {
        "schema": {"const": "ths/materialization-provenance/0.1"},
        "geometry_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "algorithm": {"const": "ths/rectangular-strip-grid/0.1"},
        "zones": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["order", "zone_id", "proposal_sha256"],
            "properties": {
              "order": {"type": "integer", "minimum": 0},
              "zone_id": {"type": "string", "minLength": 1, "maxLength": 80},
              "proposal_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
            }
          }
        }
      }
    }
  }
}
