{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://threshold.local/schema/ths-vision-proposal-0.1.json",
  "title": "Threshold private vision proposal 0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "zone_candidate", "inventory_candidates", "uncertainties"],
  "properties": {
    "schema": {"const": "ths/vision-proposal/0.1"},
    "zone_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "suggested_name",
        "outdoor_suggestion",
        "confidence",
        "evidence_frame_ids"
      ],
      "properties": {
        "candidate_id": {"const": "zone-candidate-001"},
        "suggested_name": {"type": "string", "minLength": 1, "maxLength": 80},
        "outdoor_suggestion": {"type": "boolean"},
        "confidence": {"enum": ["low", "medium", "high"]},
        "evidence_frame_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^frame-[0-9]{6}$"}
        }
      }
    },
    "inventory_candidates": {
      "type": "array",
      "maxItems": 24,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "suggested_name",
          "flags",
          "confidence",
          "evidence_frame_ids"
        ],
        "properties": {
          "candidate_id": {"type": "string", "pattern": "^inventory-candidate-[0-9]{3}$"},
          "suggested_name": {"type": "string", "minLength": 1, "maxLength": 80},
          "flags": {
            "type": "array",
            "maxItems": 3,
            "uniqueItems": true,
            "items": {"enum": ["fragile", "do-not-touch", "high-value"]}
          },
          "confidence": {"enum": ["low", "medium", "high"]},
          "evidence_frame_ids": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^frame-[0-9]{6}$"}
          }
        }
      }
    },
    "uncertainties": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "evidence_frame_ids"],
        "properties": {
          "question": {"type": "string", "minLength": 1, "maxLength": 160},
          "evidence_frame_ids": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^frame-[0-9]{6}$"}
          }
        }
      }
    }
  }
}
