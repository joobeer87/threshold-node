# Reference only. Export local values through your shell or process manager.
# Never commit a populated environment file.
# Generate long random tokens; there are intentionally no defaults.
THS_OWNER_TOKEN=
THS_DEMO_GRANT_TOKEN=
THS_BIND=127.0.0.1:8471
# These files form one private recovery boundary. Keep both in ignored,
# owner-controlled local storage and back up or restore them together.
THS_LEDGER_PATH=data/ledger.jsonl
THS_GRANT_STORE_PATH=data/grants.json
# Synthetic grants seed only on a genuinely empty first boot when this is true.
# Existing corrupt, missing-pair, or ambiguous state fails closed instead.
THS_DEMO_MODE=false
THS_ALLOW_NETWORK_BIND=false

# quietHours.timezone belongs in the canonical THS policy as an IANA name; it
# is deliberately not overridden by an environment variable.

# Optional integrations. Leave blank until configured locally.
# A live synthetic GPT-5.6 quality/cost/latency evaluation is still pending.
OPENAI_API_KEY=
HA_URL=
HA_TOKEN=
HUSQVARNA_APP_KEY=
HUSQVARNA_APP_SECRET=
ESP32_SERIAL=SIMULATED
